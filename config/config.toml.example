# tronclass_rollcall 設定範例
# 執行 `tronclass_rollcall init` 產生此檔案，複製為 config.toml 並依需求修改。
# 帳號請使用 `tronclass_rollcall account add` 新增至 accounts.db。

# ─── Provider 設定 ───────────────────────────────────────────────────────────
# 每個 provider 代表一套 Tronclass 系統（學校）。
# kind 可選：tronclass / fju / tku

[providers.fju]
kind = "fju"
base_url = "https://elearn2.fju.edu.tw"

[providers.fju.api]
base_url = "https://elearn2.fju.edu.tw"
poll_interval_secs = 10
request_timeout_secs = 30

[providers.fju.radar]
default_coords = [
    [25.0373, 121.4315],  # 輔大利瑪竇 LM
]
accuracy = 35
altitude = 0

[providers.fju.brute_force]
concurrency = 200
request_delay_ms = 0
transient_failure_threshold = 50
transient_failure_ratio = 0.20
cooldown_secs = 10
max_cooldowns = 3
min_concurrency = 10

[providers.fju.qrcode]
scanner_base_url = "https://elearn2.fju.edu.tw/scanner-jumper"
scan_timeout_secs = 60

[providers.fju.schedule]
periods = ["07:10~17:30"]
rest_weekdays = ["sun"]

# ─── Adapter 設定 ────────────────────────────────────────────────────────────

[adapters.line_bot]
enabled = false
channel_secret = "your_line_channel_secret"
channel_access_token = "your_line_channel_access_token"
webhook_port = 8080
webhook_path = "/webhook"
admin_user_id = "Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── 日誌設定 ────────────────────────────────────────────────────────────────

[logging]
level = "info"
log_to_file = false
log_file_path = "tronclass_rollcall.log"

# ─── 監控設定 ────────────────────────────────────────────────────────────────

[monitor]
startup_delay_secs = 3
retry_interval_secs = 30
max_failures_before_reauth = 5
